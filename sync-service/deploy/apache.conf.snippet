# Apache: expose the Python sync service at /sync/ alongside the PHP catalog.
# Add this inside the existing <VirtualHost> for podcasts.webosarchive.org.
# Requires: a2enmod proxy proxy_http
#
# Keep the /sync/ prefix on BOTH sides: the Flask app serves its routes under
# /sync/, so the upstream path must stay /sync/ (do not strip it).

ProxyPreserveHost On
ProxyPass        /sync/  http://127.0.0.1:8001/sync/
ProxyPassReverse /sync/  http://127.0.0.1:8001/sync/
